# Workspace environment
# 1. Copy this file:  cp .env.example .env
# 2. Run setup:       make init    (auto-detects your CakePHP app)
#
# To change the active app: make reconfigure

# --- App (set automatically by `make setup`) ---
APP_NAME=
APP_PATH=

# --- Docker project (set automatically by `make setup`) ---
COMPOSE_PROJECT_NAME=

APP_ENV=development
SERVER_NAME=localhost

# --- Ports ---
APP_HTTP_PORT=8080
APP_HTTPS_PORT=8443

# --- MariaDB (DB_DATABASE and DB_USERNAME set by `make setup`) ---
# DB_PASSWORD and DB_ROOT_PASSWORD are for local development only — never reuse in production.
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# --- phpMyAdmin ---
PMA_PORT=8081

# --- Mailpit ---
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# --- Redis ---
REDIS_PORT=6379

# --- Xdebug ---
# Set INSTALL_XDEBUG=true then run `make build` to install the extension.
# XDEBUG_MODE controls behaviour at runtime (off | debug | coverage | profile).
INSTALL_XDEBUG=false
XDEBUG_MODE=off
